// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       UserProfile?
  jobs          Job[]
  applications  Application[]
  jobScores     JobScore[]
  writingSamples WritingSample[]

  @@map("users")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Resume parsed data
  skills             String[]
  roles              String[]
  industries         String[]
  yearsExperience    Int?
  education          String[]
  technologies       String[]
  resumeUrl          String?

  // Onboarding data
  jobTitle           String?
  targetIndustries   String[]
  desiredSalaryMin   Float?
  desiredSalaryMax   Float?
  jobType            String[] // "remote", "hybrid", "onsite", "any"
  willingToRelocate  Boolean  @default(false)
  careerGoals        String?
  additionalInfo     String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("user_profiles")
}

model WritingSample {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  title      String
  type       String   // "cover_letter", "bio", "summary"
  content    String   @db.Text
  
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("writing_samples")
}

model Job {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title          String
  company        String
  description    String   @db.Text
  requirements   String   @db.Text
  salary         String?
  location       String?
  jobType        String?  // "remote", "hybrid", "onsite"
  url            String?
  source         String   // "manual", "linkedin", "indeed", etc.

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applications   Application[]
  jobScores      JobScore[]

  @@map("jobs")
}

model Application {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Kanban board fields
  company   String
  role      String
  status    String   @default("applied") // "applied", "phone_screen", "interview", "offer", "rejected"
  appliedAt DateTime @default(now())
  dateApplied String? // YYYY-MM-DD format for Kanban UI
  url       String?
  notes     String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("applications")
}


model JobScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  score     Float    // 0-100
  reasoning String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
  @@map("job_scores")
}
