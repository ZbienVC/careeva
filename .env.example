# Database
DATABASE_URL=postgresql://user:password@host:port/database

# Authentication
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# API Keys
OPENAI_API_KEY=sk-proj-...
GEMINI_API_KEY=AIzaSy...

# Public Config
NEXT_PUBLIC_API_URL=http://localhost:3000
NODE_ENV=development
# ── Job Search APIs ──────────────────────────────────────────────────────────
# SerpAPI - Google Jobs search (best source, covers Indeed/LinkedIn/Glassdoor)
# Get free API key at https://serpapi.com (100 searches/month free)
SERP_API_KEY=your_serpapi_key_here

# Adzuna - Free job board API (250 calls/day free)
# Register at https://developer.adzuna.com
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# ── Auto-Apply Settings ──────────────────────────────────────────────────────
# Default apply mode: 'auto' | 'review_first' | 'prep_only'
# Start with 'review_first' until you trust the system
AUTO_APPLY_MODE=review_first
# ── Free Job Sources ─────────────────────────────────────────────────────────
# SerpAPI - Google Jobs (100 free/month) - covers LinkedIn/Indeed/Glassdoor/company sites
# https://serpapi.com/manage-api-key
SERP_API_KEY=

# RapidAPI JSearch - 60 free/month - aggregates LinkedIn, Indeed, ZipRecruiter, Glassdoor
# https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch (free tier)
RAPIDAPI_KEY=

# USA Jobs - completely free, US government jobs
# https://developer.usajobs.gov/
USAJOBS_HOST=
USAJOBS_KEY=

# Adzuna - 250 free calls/day
# https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Default: remotive + themuse + adzuna + indeed + arbeitnow + weworkremotely all work with NO API keys
# ── AI Configuration ─────────────────────────────────────────────────────────
# Claude Sonnet 4.6 - RECOMMENDED for best cover letters and resume writing
# Get key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o-mini - used for quick answers and scoring rationale
# Also used as fallback if no Anthropic key
# OPENAI_API_KEY already set above

# AI routing:
# - Cover letters: Claude Sonnet 4.6 (if ANTHROPIC_API_KEY set), else GPT-4o-mini
# - Resume summaries: Claude Sonnet 4.6 (if ANTHROPIC_API_KEY set), else GPT-4o-mini
# - Short answers, scoring: GPT-4o-mini
# - Fallback: if only OPENAI_API_KEY set, all tasks use GPT-4o-mini