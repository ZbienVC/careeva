// Careeva Гўв‚¬вЂќ Prisma Schema
// Personal-use-first job application operating system
// Extended schema: profile engine, materials library, job pipeline, application tracker

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ AUTH ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Profile engine
  profile            UserProfile?
  personalInfo       PersonalInfo?
  workHistory        WorkHistory[]
  educationEntries   EducationEntry[]
  projects           Project[]
  certifications     Certification[]
  socialLinks        SocialLink[]
  skills             Skill[]
  jobPreferences     JobPreferences?
  writingPreferences WritingPreferences?
  autoApplyConfig    AutoApplyConfig?

  // Materials
  resumes           Resume[]
  coverLetters      CoverLetter[]
  reusableAnswers   ReusableAnswer[]
  writingSamples    WritingSample[]

  // Job pipeline
  jobs       Job[]
  jobScores  JobScore[]
  scrapeRuns ScrapeRun[]

  // Applications
  applications Application[]

  // Generation
  generationRuns GenerationRun[]

  @@map("users")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ PROFILE ENGINE ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

// Legacy flat profile Гўв‚¬вЂќ kept for backward compat, gradually migrated
model UserProfile {
  id                 String   @id @default(cuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  skills             String[]
  roles              String[]
  industries         String[]
  yearsExperience    Int?
  education          String[]
  technologies       String[]
  resumeUrl          String?

  jobTitle           String?
  targetIndustries   String[]
  desiredSalaryMin   Float?
  desiredSalaryMax   Float?
  jobType            String[]
  willingToRelocate  Boolean  @default(false)
  careerGoals        String?
  additionalInfo     String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("user_profiles")
}

// Rich personal/contact info
model PersonalInfo {
  id              String  @id @default(cuid())
  userId          String  @unique
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName        String?
  preferredName   String?
  email           String?
  phone           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  state           String?
  zipCode         String?
  country         String?  @default("US")

  timezone        String?
  linkedinUrl     String?
  githubUrl       String?
  portfolioUrl    String?
  websiteUrl      String?
  otherLinks      Json?    // [{label, url}]

  // Work auth
  workAuthorization   String?  // "us_citizen", "green_card", "h1b", "opt", "other"
  requiresSponsorship Boolean  @default(false)
  sponsorshipNote     String?

  // Availability
  noticePeriodDays    Int?
  availableStartDate  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("personal_info")
}

// Structured work history entry
model WorkHistory {
  id          String  @id @default(cuid())
  userId      String
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  company     String
  title       String
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean  @default(false)
  location    String?
  isRemote    Boolean  @default(false)

  // Rich content
  summary     String?  @db.Text
  bullets     ResumeBullet[]

  // Tagging for role-family matching
  roleFamilies   String[]  // "analytics", "ops", "fintech", "crypto", etc.
  skills         String[]
  technologies   String[]

  // Order for display
  sortOrder   Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("work_history")
}

// Individual resume bullets Гўв‚¬вЂќ stored separately for tailoring
model ResumeBullet {
  id            String      @id @default(cuid())
  workHistoryId String?
  workHistory   WorkHistory? @relation(fields: [workHistoryId], references: [id], onDelete: Cascade)
  projectId     String?
  project       Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)

  content       String      @db.Text
  isQuantified  Boolean     @default(false)
  metric        String?     // e.g. "increased by 40%"

  // Tagging
  roleFamilies  String[]
  skills        String[]
  isHighlight   Boolean     @default(false)

  sortOrder     Int         @default(0)

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("resume_bullets")
}

model EducationEntry {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  institution  String
  degree       String?
  fieldOfStudy String?
  startDate    DateTime?
  endDate      DateTime?
  isCurrent    Boolean  @default(false)
  gpa          String?
  honors       String?
  notes        String?  @db.Text

  sortOrder    Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("education_entries")
}

model Project {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  description  String?  @db.Text
  url          String?
  startDate    DateTime?
  endDate      DateTime?
  isOngoing    Boolean  @default(false)

  roleFamilies String[]
  skills       String[]
  technologies String[]
  bullets      ResumeBullet[]

  sortOrder    Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("projects")
}

model Certification {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  issuer       String?
  issueDate    DateTime?
  expiryDate   DateTime?
  credentialId String?
  credentialUrl String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("certifications")
}

model SocialLink {
  id       String   @id @default(cuid())
  userId   String
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  platform String   // "linkedin", "github", "portfolio", "twitter", "other"
  url      String
  label    String?

  @@map("social_links")
}

model Skill {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String
  category     String?  // "technical", "soft", "tool", "language", "domain"
  proficiency  String?  // "expert", "proficient", "familiar"
  yearsUsed    Int?
  roleFamilies String[]

  createdAt    DateTime @default(now())

  @@map("skills")
}

// Job search targeting preferences
model JobPreferences {
  id          String  @id @default(cuid())
  userId      String  @unique
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  targetTitles      String[]
  targetFunctions   String[]
  targetIndustries  String[]
  targetCompanyTypes String[]  // "startup", "enterprise", "nonprofit", "agency"
  roleFamilies      String[]

  // Compensation
  salaryMinUSD     Int?
  salaryMaxUSD     Int?
  salaryNote       String?

  // Location
  preferredLocations String[]
  remotePreference   String?   // "remote_only", "hybrid_ok", "onsite_ok", "any"
  willingToRelocate  Boolean   @default(false)
  relocationNote     String?

  // Work type
  fullTimeOk         Boolean   @default(true)
  partTimeOk         Boolean   @default(false)
  contractOk         Boolean   @default(false)

  // Other
  willingToTravel    Boolean   @default(false)
  travelPercent      Int?
  seniority          String[]  // "ic", "senior", "staff", "lead", "manager"

  updatedAt          DateTime  @updatedAt

  @@map("job_preferences")
}

model WritingPreferences {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tone descriptors
  toneWords    String[]  // "concise", "authentic", "direct", "warm", "professional"
  avoidWords   String[]  // words/phrases to avoid
  exampleBio   String?   @db.Text
  positioningStatement String? @db.Text

  // Per role-family tone overrides
  roleFamilyTones Json?  // { "fintech": "professional", "startup": "casual" }

  updatedAt DateTime @updatedAt

  @@map("writing_preferences")
}

model AutoApplyConfig {
  id     String  @id @default(cuid())
  userId String  @unique
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Global switches
  autoApplyEnabled       Boolean  @default(false)
  defaultMode            String   @default("prep_only")
  // modes: discover_only | save_for_review | prep_only | autofill_draft | safe_auto | full_auto

  // Limits
  maxApplicationsPerDay  Int      @default(5)
  requireResumeReview    Boolean  @default(true)
  requireCoverReview     Boolean  @default(true)

  // Safety
  stopOnCaptcha          Boolean  @default(true)
  stopOnUnknownQuestion  Boolean  @default(true)
  stopOnLowConfidence    Boolean  @default(true)
  confidenceThreshold    Float    @default(0.75)

  // Score gates
  minScoreToApply        Float    @default(60.0)
  minScoreToAutoApply    Float    @default(75.0)

  // Source-level enables
  enabledSources   String[]  // ["greenhouse", "lever", "workday"]
  disabledAts      String[]  // specific ATS types to skip

  // Company filters
  companyBlacklist String[]
  companyPriority  String[]
  titleWhitelist   String[]
  titleBlacklist   String[]

  updatedAt DateTime @updatedAt

  @@map("auto_apply_config")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ MATERIALS LIBRARY ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Resume {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name      String   // "Master Resume", "Analytics Focus", "Fintech v2"
  fileUrl   String?  // object storage URL
  fileType  String?  // "pdf", "docx"
  isBase    Boolean  @default(false)  // the master/base resume

  // Role family this variant targets (empty = general)
  roleFamilies String[]

  // Parsed sections (stored after parse)
  sections  ResumeSection[]

  // Raw text (for search/grounding)
  rawText   String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applicationDocuments ApplicationDocument[]

  @@map("resumes")
}

model ResumeSection {
  id        String  @id @default(cuid())
  resumeId  String
  resume    Resume  @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  type      String  // "summary", "experience", "education", "skills", "projects", "certifications"
  title     String?
  content   String  @db.Text
  sortOrder Int     @default(0)

  @@map("resume_sections")
}

model CoverLetter {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name         String?
  jobId        String?
  jobTitle     String?
  company      String?
  content      String   @db.Text
  tone         String?  // "professional", "warm", "direct"
  roleFamilies String[]
  isTemplate   Boolean  @default(false)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applicationDocuments ApplicationDocument[]

  @@map("cover_letters")
}

// Reusable application Q&A bank
model ReusableAnswer {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Question normalization
  questionKey     String   // normalized key: "work_authorization", "salary_expectation", "why_this_role"
  questionFamily  String   // "legal", "compensation", "logistics", "experience", "behavioral"
  questionText    String?  @db.Text  // original question text that triggered this

  // Answer
  answer          String   @db.Text
  answerShort     String?  @db.Text  // <=100 char version
  answerLong      String?  @db.Text  // expanded version

  // Confidence + review
  isVerified      Boolean  @default(false)
  isAutoGenerated Boolean  @default(false)
  confidence      Float?

  // Scoping
  roleFamilies    String[]
  companyTypes    String[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, questionKey])
  @@map("reusable_answers")
}

model WritingSample {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  type      String   // "cover_letter", "bio", "summary", "answer", "positioning"
  content   String   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("writing_samples")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ JOB PIPELINE ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Job {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Core
  title          String
  company        String
  description    String   @db.Text
  requirements   String   @db.Text
  salary         String?
  salaryMin      Int?
  salaryMax      Int?
  location       String?
  isRemote       Boolean  @default(false)
  isHybrid       Boolean  @default(false)
  jobType        String?

  // Source tracking
  url            String?
  applyUrl       String?
  source         String   @default("manual")  // "greenhouse", "lever", "workday", "linkedin", "manual"
  externalId     String?   // ID from source ATS
  atsType        String?   // "greenhouse", "lever", "workday", "ashby", "icims", "smartrecruiters"

  // Dedup
  dedupeKey      String?   // hash of company+title+location for dedup
  isDuplicate    Boolean   @default(false)
  canonicalJobId String?   // points to the canonical version if duplicate

  // Freshness
  postedAt       DateTime?
  expiresAt      DateTime?
  isActive       Boolean  @default(true)
  lastScrapedAt  DateTime?

  // Scoring metadata
  roleFamilies   String[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  applications  Application[]
  jobScores     JobScore[]
  scrapeRunId   String?
  scrapeRun     ScrapeRun? @relation(fields: [scrapeRunId], references: [id], onDelete: SetNull)

  @@index([userId, isActive])
  @@index([dedupeKey])
  @@map("jobs")
}

model JobScore {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  // Composite score
  score          Float
  overallScore   Float    @default(0)

  // Dimension scores
  skillScore     Float?
  roleScore      Float?
  techScore      Float?
  experienceScore Float?
  locationScore  Float?
  compensationScore Float?
  roleFamilyScore Float?

  // Recommendation
  recommendation String?  // "auto_apply", "autofill_draft", "save_for_review", "ignore"
  reasoning      String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
  @@map("job_scores")
}

model ScrapeRun {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  source      String   // "greenhouse", "lever", "workday", "manual"
  status      String   @default("pending")  // "pending", "running", "complete", "failed"
  jobsFound   Int      @default(0)
  jobsNew     Int      @default(0)
  jobsDuped   Int      @default(0)
  errorMessage String?  @db.Text

  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())

  jobs        Job[]

  @@map("scrape_runs")
}

// Company registry for dedup and enrichment
model Company {
  id           String   @id @default(cuid())
  name         String   @unique
  aliases      String[]
  domain       String?
  atsType      String?
  careerPageUrl String?
  greenhouseId String?
  leverId      String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("companies")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ APPLICATION TRACKER ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model Application {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String?
  job       Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Core kanban fields
  company     String
  role        String
  status      String   @default("saved")
  // statuses: saved | prepping | applied | phone_screen | interview | offer | rejected | withdrawn | archived

  appliedAt   DateTime?
  dateApplied String?
  url         String?
  applyUrl    String?
  notes       String?  @db.Text

  // ATS metadata
  atsType     String?
  externalApplicationId String?

  // Submission details
  submittedVia String?  // "manual", "auto", "autofill"
  automationRunId String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  documents   ApplicationDocument[]
  answers     ApplicationAnswer[]
  events      ApplicationEvent[]
  artifacts   ApplicationArtifact[]
  automationRun AutomationRun? @relation(fields: [automationRunId], references: [id], onDelete: SetNull)

  @@map("applications")
}

// Which docs were submitted with an application
model ApplicationDocument {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type          String   // "resume", "cover_letter"
  resumeId      String?
  resume        Resume?  @relation(fields: [resumeId], references: [id], onDelete: SetNull)
  coverLetterId String?
  coverLetter   CoverLetter? @relation(fields: [coverLetterId], references: [id], onDelete: SetNull)

  fileUrl       String?  // snapshot URL at time of application
  createdAt     DateTime @default(now())

  @@map("application_documents")
}

// Per-question answers stored per application
model ApplicationAnswer {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  questionText  String   @db.Text
  questionKey   String?  // normalized key if matched
  answer        String   @db.Text
  isAutoGenerated Boolean @default(false)
  confidence    Float?
  needsReview   Boolean  @default(false)

  createdAt     DateTime @default(now())

  @@map("application_answers")
}

// Application status event log
model ApplicationEvent {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  eventType     String   // "status_change", "note_added", "interview_scheduled", "offer_received"
  fromStatus    String?
  toStatus      String?
  note          String?  @db.Text
  metadata      Json?

  createdAt     DateTime @default(now())

  @@map("application_events")
}

// Screenshots, logs, artifacts per application
model ApplicationArtifact {
  id            String   @id @default(cuid())
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  type          String   // "screenshot", "log", "generated_answer", "error"
  url           String?
  content       String?  @db.Text
  metadata      Json?

  createdAt     DateTime @default(now())

  @@map("application_artifacts")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ AUTOMATION ENGINE ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model AutomationRun {
  id          String   @id @default(cuid())
  userId      String?
  jobId       String?

  status      String   @default("pending")
  // pending | running | paused | complete | failed | needs_review

  mode        String   @default("prep_only")
  atsType     String?
  url         String?

  startedAt   DateTime?
  completedAt DateTime?
  pausedAt    DateTime?

  // Results
  stepsCompleted Int    @default(0)
  stepsFailed    Int    @default(0)
  lastCheckpoint String?
  failureReason  String? @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tasks       AutomationTask[]
  applications Application[]

  @@map("automation_runs")
}

model AutomationTask {
  id              String   @id @default(cuid())
  automationRunId String
  automationRun   AutomationRun @relation(fields: [automationRunId], references: [id], onDelete: Cascade)

  stepName        String   // "detect_ats", "fill_name", "upload_resume", "answer_question", "submit"
  status          String   @default("pending")
  inputData       Json?
  outputData      Json?
  errorMessage    String?  @db.Text
  screenshotUrl   String?

  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())

  @@map("automation_tasks")
}

// ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ AI GENERATION ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬ГўвЂќв‚¬

model GenerationRun {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type       String   // "cover_letter", "resume_bullet", "answer", "summary", "tailored_resume"
  model      String   @default("gpt-4o-mini")
  promptKey  String?

  // Input context
  jobId      String?
  jobTitle   String?
  company    String?

  // Grounding inputs used
  groundedFields String[]  // which profile fields were used

  // Output
  output     String?  @db.Text
  isApproved Boolean  @default(false)
  feedback   String?

  createdAt  DateTime @default(now())

  @@map("generation_runs")
}
